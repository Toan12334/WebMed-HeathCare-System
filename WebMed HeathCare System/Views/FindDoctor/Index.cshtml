@model IEnumerable<WebMed_HeathCare_System.Models.Doctor>

@{
    ViewData["Title"] = "Đội Ngũ Bác Sĩ Chuyên Khoa - WebMed";
}

<div class="container mt-4 pb-5">
    <!-- Header Block -->
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark text-uppercase tracking-wide" style="font-size: 2rem; letter-spacing: 1px;">
            Đội Ngũ Bác Sĩ Chuyên Khoa
        </h2>
        <div class="mx-auto bg-emerald mb-3" style="width: 60px; height: 4px; border-radius: 2px;"></div>
    </div>

    <!-- Top Filters Form -->
    <form asp-action="Index" method="get" id="filterForm" class="mb-5">
        <!-- Preserve selected specialty when submitting top filters -->
        <input type="hidden" name="specialty" value="@ViewBag.SelectedSpecialty" />

        <div class="bg-white p-4 rounded-4 shadow-sm border border-light">
            <div class="row g-3 align-items-center">
                <!-- Location / Clinic -->
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-geo-alt text-muted"></i></span>
                        <select name="location" class="form-select bg-light border-0 py-2 fs-7" onchange="this.form.submit()">
                            <option value="">Tất cả khu vực</option>
                            @foreach (var loc in (List<string>)ViewBag.Locations)
                            {
                                <!option value="@loc" @(ViewBag.SelectedLocation == loc ? "selected" : "")>@loc</!option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Position -->
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-briefcase text-muted"></i></span>
                        <select name="position" class="form-select bg-light border-0 py-2 fs-7" onchange="this.form.submit()">
                            <option value="">Tất cả chức vụ</option>
                            @foreach (var pos in (List<string>)ViewBag.Positions)
                            {
                                <!option value="@pos" @(ViewBag.SelectedPosition == pos ? "selected" : "")>
                                    @(pos == "director" ? "Giám đốc / Quản lý" : pos == "expert" ? "Cố vấn chuyên gia" : pos == "specialist" ? "Bác sĩ chuyên khoa" : "Cố vấn")
                                </!option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Rank / Degree -->
                <div class="col-md-2">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-mortarboard text-muted"></i></span>
                        <select name="rank" class="form-select bg-light border-0 py-2 fs-7" onchange="this.form.submit()">
                            <option value="">Học hàm / Học vị</option>
                            @foreach (var rk in (List<string>)ViewBag.Ranks)
                            {
                                <!option value="@rk" @(ViewBag.SelectedRank == rk ? "selected" : "")>@rk</!option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Search Input -->
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchTerm" class="form-control bg-light border-0 py-2 fs-7" 
                               placeholder="Tìm kiếm bác sĩ theo tên hoặc tiểu sử..." value="@ViewBag.SearchTerm" />
                        <button type="submit" class="btn btn-emerald px-3"><i class="bi bi-search"></i></button>
                    </div>
                </div>
            </div>

            <!-- Active Filters Indicators -->
            @if (!string.IsNullOrEmpty(ViewBag.SelectedLocation) || !string.IsNullOrEmpty(ViewBag.SelectedPosition) || !string.IsNullOrEmpty(ViewBag.SelectedRank) || !string.IsNullOrEmpty(ViewBag.SearchTerm) || !string.IsNullOrEmpty(ViewBag.SelectedSpecialty))
            {
                <div class="d-flex flex-wrap gap-2 align-items-center mt-3 pt-3 border-top border-light">
                    <span class="small text-muted me-2">Bộ lọc đang áp dụng:</span>
                    
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedSpecialty))
                    {
                        <span class="badge bg-emerald-100 text-emerald-800 px-3 py-1 rounded-pill">
                            Chuyên khoa: @ViewBag.SelectedSpecialty
                            <a href="?specialty=&location=@ViewBag.SelectedLocation&position=@ViewBag.SelectedPosition&rank=@ViewBag.SelectedRank&searchTerm=@ViewBag.SearchTerm" class="text-emerald-800 ms-1"><i class="bi bi-x-circle-fill"></i></a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedLocation))
                    {
                        <span class="badge bg-light text-dark px-3 py-1 rounded-pill border">
                            Khu vực: @ViewBag.SelectedLocation
                            <a href="?specialty=@ViewBag.SelectedSpecialty&location=&position=@ViewBag.SelectedPosition&rank=@ViewBag.SelectedRank&searchTerm=@ViewBag.SearchTerm" class="text-dark ms-1"><i class="bi bi-x-circle-fill"></i></a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedPosition))
                    {
                        <span class="badge bg-light text-dark px-3 py-1 rounded-pill border">
                            Chức vụ: @(ViewBag.SelectedPosition == "director" ? "Giám đốc / Quản lý" : ViewBag.SelectedPosition == "expert" ? "Cố vấn chuyên gia" : ViewBag.SelectedPosition == "specialist" ? "Bác sĩ chuyên khoa" : "Cố vấn")
                            <a href="?specialty=@ViewBag.SelectedSpecialty&location=@ViewBag.SelectedLocation&position=&rank=@ViewBag.SelectedRank&searchTerm=@ViewBag.SearchTerm" class="text-dark ms-1"><i class="bi bi-x-circle-fill"></i></a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedRank))
                    {
                        <span class="badge bg-light text-dark px-3 py-1 rounded-pill border">
                            Học vị: @ViewBag.SelectedRank
                            <a href="?specialty=@ViewBag.SelectedSpecialty&location=@ViewBag.SelectedLocation&position=@ViewBag.SelectedPosition&rank=&searchTerm=@ViewBag.SearchTerm" class="text-dark ms-1"><i class="bi bi-x-circle-fill"></i></a>
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                    {
                        <span class="badge bg-light text-dark px-3 py-1 rounded-pill border">
                            Từ khóa: "@ViewBag.SearchTerm"
                            <a href="?specialty=@ViewBag.SelectedSpecialty&location=@ViewBag.SelectedLocation&position=@ViewBag.SelectedPosition&rank=@ViewBag.SelectedRank&searchTerm=" class="text-dark ms-1"><i class="bi bi-x-circle-fill"></i></a>
                        </span>
                    }
                    
                    <a href="?" class="btn btn-link btn-sm text-danger p-0 ms-auto">Xóa tất cả bộ lọc</a>
                </div>
            }
        </div>
    </form>

    <!-- Main Section: Sidebar + Content -->
    <div class="row">
        <!-- Sidebar: Specialties -->
        <div class="col-md-3 mb-4">
            <div class="bg-white rounded-4 shadow-sm border border-light overflow-hidden">
                <div class="p-3 bg-light border-bottom">
                    <h5 class="fw-bold text-dark mb-0 fs-6"><i class="bi bi-filter-left me-2"></i>Chuyên Khoa</h5>
                </div>
                <div class="list-group list-group-flush specialty-sidebar-list">
                    <!-- All Specialties -->
                    <a href="?specialty=&location=@ViewBag.SelectedLocation&position=@ViewBag.SelectedPosition&rank=@ViewBag.SelectedRank&searchTerm=@ViewBag.SearchTerm" 
                       class="list-group-item list-group-item-action py-3 px-4 fw-bold fs-7 @(string.IsNullOrEmpty(ViewBag.SelectedSpecialty) ? "active-specialty" : "")">
                        Tất cả chuyên khoa
                    </a>
                    
                    @foreach (var spec in (List<string>)ViewBag.Specialties)
                    {
                        <a href="?specialty=@spec&location=@ViewBag.SelectedLocation&position=@ViewBag.SelectedPosition&rank=@ViewBag.SelectedRank&searchTerm=@ViewBag.SearchTerm" 
                           class="list-group-item list-group-item-action py-3 px-4 fw-bold fs-7 @(ViewBag.SelectedSpecialty == spec ? "active-specialty" : "")">
                            @spec
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Right Content: Doctors Grid -->
        <div class="col-md-9">
            <div class="row">
                @if (Model != null && Model.Any())
                {
                    @foreach (var doctor in Model)
                    {
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden text-center hover-lift position-relative">
                                <!-- Background Decorative Arc -->
                                <div class="bg-light-blue-arc" style="height: 120px; background: linear-gradient(180deg, #dbeafe 0%, #ffffff 100%);"></div>
                                
                                <div class="card-body p-4 pt-0 d-flex flex-column align-items-center" style="margin-top: -60px;">
                                    <!-- Doctor Avatar Container -->
                                    <div class="position-relative mb-3">
                                        <img src="~/images/doctor.png" alt="@doctor.DoctorNavigation.FullName" 
                                             class="rounded-circle border border-4 border-white shadow" 
                                             style="width: 110px; height: 110px; object-fit: cover; background-color: #f3f4f6;" />
                                        @if (doctor.IsVerified)
                                        {
                                            <span class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center border border-2 border-white" 
                                                  style="width: 24px; height: 24px; font-size: 0.75rem;" title="Bác sĩ chuyên gia đã xác thực">
                                                <i class="bi bi-patch-check-fill"></i>
                                            </span>
                                        }
                                    </div>

                                    <!-- Doctor Name and Titles -->
                                    <h5 class="fw-bold mb-1 px-2" style="color: #1e3a8a; min-height: 48px; font-size: 1.1rem; line-height: 1.3;">
                                        @doctor.DoctorNavigation.FullName
                                    </h5>
                                    
                                    <!-- Specialty badge -->
                                    <span class="badge rounded-pill bg-light text-emerald px-3 py-1 mb-2 fw-semibold fs-8" 
                                          style="border: 1px solid #a7f3d0; color: var(--primary-color);">
                                        @doctor.Specialty
                                    </span>

                                    <!-- Bio/Position description -->
                                    <p class="text-muted fs-7 mb-4 px-1 flex-grow-1" style="min-height: 60px; line-height: 1.5;">
                                        @(doctor.Bio?.Length > 120 ? doctor.Bio.Substring(0, 117) + "..." : doctor.Bio ?? "Chưa cập nhật tiểu sử bác sĩ.")
                                    </p>

                                    <!-- Action Button -->
                                    <a asp-action="Details" asp-route-id="@doctor.DoctorId" 
                                       class="btn btn-dark w-100 rounded-pill py-2.5 fw-bold text-white shadow-sm mt-auto transition-all d-flex align-items-center justify-content-center gap-2"
                                       style="background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); border: none;">
                                        <i class="bi bi-calendar-check-fill fs-8"></i> Đặt Lịch Ngay
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-people text-muted mb-3" style="font-size: 3.5rem;"></i>
                        <h3 class="fw-bold">Không tìm thấy bác sĩ nào</h3>
                        <p class="text-muted px-4">Chúng tôi không tìm thấy chuyên gia y tế nào khớp với tiêu chí tìm kiếm của bạn. Hãy thử xóa bộ lọc hoặc đổi khu vực khác.</p>
                        <a href="?" class="btn btn-emerald rounded-pill px-4 mt-2">Đặt lại bộ lọc</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.9rem !important;
    }
    .fs-8 {
        font-size: 0.8rem !important;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.06) !important;
    }
    .transition-all {
        transition: all 0.25s ease-in-out;
    }
    .bg-emerald {
        background-color: var(--primary-color) !important;
    }
    .btn-emerald {
        background-color: var(--primary-color);
        color: white;
        border: none;
    }
    .btn-emerald:hover {
        background-color: var(--primary-hover);
        color: white;
    }
    
    /* Sidebar styling matching screenshot */
    .specialty-sidebar-list .list-group-item {
        border-left: 4px solid transparent;
        color: #475569;
        transition: all 0.2s ease;
    }
    .specialty-sidebar-list .list-group-item:hover {
        background-color: #f8fafc;
        color: var(--primary-color);
        padding-left: 1.75rem !important;
    }
    .specialty-sidebar-list .active-specialty {
        background-color: #f0fdf4 !important;
        border-left: 4px solid var(--primary-color) !important;
        color: var(--primary-color) !important;
    }
</style>
