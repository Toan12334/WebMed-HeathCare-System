@model WebMed_HeathCare_System.Models.Doctor

@{
    ViewData["Title"] = Model.DoctorNavigation.FullName + " - Chi Tiết Bác Sĩ";
    decimal fee = ViewBag.Fee;
}

<div class="container mt-5 mb-5">
    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted mb-4"><i class="bi bi-arrow-left"></i> Quay lại Danh Sách Bác Sĩ</a>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Left Side: Doctor Info card -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                <div class="bg-emerald-100 text-emerald-800 rounded-circle p-4 mx-auto mb-3" style="width: 100px; height: 100px; display: flex; align-items: center; justify-content: center; background-color: #d1fae5; color: #065f46;">
                    <i class="bi bi-person-bounding-box" style="font-size: 3rem;"></i>
                </div>
                
                <h3 class="fw-bold mb-1">@Model.DoctorNavigation.FullName</h3>
                <span class="badge bg-light text-emerald px-3 py-2 rounded-pill fw-bold text-uppercase border mb-3" style="color: #059669; border-color: #a7f3d0 !important;">@Model.Specialty</span>
                
                <div class="d-flex justify-content-center align-items-center mb-3">
                    <span class="text-warning me-1"><i class="bi bi-star-fill"></i></span>
                    <strong class="fs-5">@Model.AverageRating.ToString("F1")</strong>
                    <span class="text-muted ms-1">/ 5.0 Đánh Giá</span>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4 text-start">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted"><i class="bi bi-geo-alt-fill text-danger me-1"></i> Khu Vực:</span>
                        <strong class="text-dark">@Model.Location</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted"><i class="bi bi-credit-card-fill text-success me-1"></i> Phí Tư Vấn:</span>
                        <strong class="text-success">@fee.ToString("N0") VND</strong>
                    </div>
                </div>

                <h5 class="fw-bold text-dark text-start mb-2">Giới Thiệu & Tiểu Sử</h5>
                <p class="text-muted text-start fs-7 mb-0" style="line-height: 1.6;">
                    @Model.Bio
                </p>
            </div>
        </div>

        <!-- Right Side: Schedule & Slots selection -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h4 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="bi bi-calendar-check text-emerald"></i> Lịch Hẹn Khám Sẵn Có</h4>
                
                @if (Model.AvailabilitySlots != null && Model.AvailabilitySlots.Any())
                {
                    <p class="text-muted fs-7 mb-4">Chọn một khung thời gian rảnh dưới đây để đặt lịch hẹn trực tuyến của bạn.</p>
                    
                    <div class="row g-3">
                        @foreach (var slot in Model.AvailabilitySlots)
                        {
                            <div class="col-sm-6">
                                <div class="border rounded-3 p-3 hover-shadow transition-all bg-light-hover position-relative">
                                    <div class="mb-2">
                                        <i class="bi bi-clock-fill text-muted me-1"></i> <strong>@slot.StartDateTime.ToString("hh:mm tt") - @slot.EndDateTime.ToString("hh:mm tt")</strong>
                                    </div>
                                    <div class="fs-7 text-muted mb-3">
                                        <i class="bi bi-calendar-event me-1"></i> @slot.StartDateTime.ToString("dddd, MMMM dd, yyyy")
                                    </div>
                                    
                                    <form asp-controller="Appointment" asp-action="Book" method="post">
                                        <input type="hidden" name="slotId" value="@slot.SlotId" />
                                        <button type="submit" class="btn btn-emerald btn-sm w-100 rounded-pill fw-bold" style="background-color: #059669; color: white;">Đặt Lịch Khung Giờ Này</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x text-muted mb-3" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold">Không có lịch hẹn nào</h5>
                        <p class="text-muted">Chuyên gia này chưa đăng ký lịch trống sắp tới. Vui lòng quay lại sau hoặc chọn một bác sĩ khác.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .text-emerald {
        color: #059669 !important;
    }
    .fs-7 {
        font-size: 0.88rem;
    }
    .hover-shadow:hover {
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        border-color: #a7f3d0 !important;
    }
    .bg-light-hover:hover {
        background-color: #f0fdf4 !important;
    }
    .transition-all {
        transition: all 0.2s ease;
    }
</style>
