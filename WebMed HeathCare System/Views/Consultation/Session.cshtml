@model WebMed_HeathCare_System.Models.Appointment

@{
    ViewData["Title"] = "Phiên Tư Vấn";
    var role = ViewBag.Role;
}

<div class="container-fluid mt-4 mb-5 px-4">
    <div class="row g-4">
        <!-- Left Column: Video call simulator -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-dark text-white">
                <div class="card-header bg-dark border-0 p-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold"><i class="bi bi-camera-video"></i> Phòng Tư Vấn Trực Tuyến</h5>
                    <span class="badge bg-danger animate-pulse"><i class="bi bi-circle-fill fs-8"></i> TRỰC TIẾP</span>
                </div>
                
                <!-- Simulated Video Stream -->
                <div class="position-relative" style="height: 480px; background-color: #1a1d20;">
                    <!-- Remote participant video simulation -->
                    <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-center">
                        <div class="rounded-circle bg-secondary p-4 mb-3" style="width: 120px; height: 120px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-person-fill" style="font-size: 4rem;"></i>
                        </div>
                        <h4 class="fw-bold">
                            @(role == "Doctor" ? Model.Patient.PatientNavigation.FullName : Model.Doctor.DoctorNavigation.FullName)
                        </h4>
                        <p class="text-muted fs-7">Đã kết nối qua Đường truyền Video Bảo mật</p>
                    </div>

                    <!-- Local participant preview picture-in-picture -->
                    <div class="position-absolute bottom-0 end-0 m-3 rounded-3 overflow-hidden shadow-lg border border-secondary" style="width: 160px; height: 120px; background-color: #2b3035;">
                        <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-center">
                            <i class="bi bi-person-video" style="font-size: 2rem;"></i>
                            <small class="fs-8 text-light mt-1">Bạn</small>
                        </div>
                    </div>
                </div>

                <!-- Call Action Controls -->
                <div class="card-footer bg-dark border-0 p-3 d-flex justify-content-center gap-3">
                    <button class="btn btn-outline-light rounded-circle p-3"><i class="bi bi-mic-fill fs-5"></i></button>
                    <button class="btn btn-outline-light rounded-circle p-3"><i class="bi bi-camera-video-fill fs-5"></i></button>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-danger rounded-pill px-4 py-3 fw-bold"><i class="bi bi-telephone-x-fill"></i> Kết thúc Tư vấn</a>
                </div>
            </div>
        </div>

        <!-- Right Column: Medical records & Forms -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 h-100">
                @if (role == "Doctor")
                {
                    <h3 class="fw-bold text-dark border-bottom pb-2 mb-4"><i class="bi bi-journal-medical text-emerald"></i> Hồ sơ kết quả khám lâm sàng</h3>
                    
                    <form asp-action="SubmitConsultation" method="post" id="consultForm">
                        <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />
                        <input type="hidden" id="prescriptionJson" name="prescriptionJson" value="" />

                        <!-- Diagnosis -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Chẩn đoán lâm sàng</label>
                            <textarea name="diagnosis" class="form-control rounded-3" rows="3" required placeholder="Nhập chi tiết chẩn đoán lâm sàng..."></textarea>
                        </div>

                        <!-- Treatment Plan -->
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Kế hoạch điều trị / Khuyến nghị</label>
                            <textarea name="treatmentPlan" class="form-control rounded-3" rows="3" placeholder="Nhập hướng dẫn điều trị, chế độ ăn uống, nghỉ ngơi..."></textarea>
                        </div>

                        <!-- Prescription Builder -->
                        <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Danh mục đơn thuốc</h5>
                        
                        <div class="mb-3 position-relative">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                                <input type="text" id="medicineSearch" class="form-control border-start-0" placeholder="Tìm kiếm trong danh mục thuốc..." autocomplete="off" />
                            </div>
                            <div id="searchResults" class="list-group position-absolute w-100 shadow-sm z-3 d-none"></div>
                        </div>

                        <!-- Prescribed Medicines Table -->
                        <div class="table-responsive mb-4" style="max-height: 200px;">
                            <table class="table table-sm align-middle" id="prescriptionTable">
                                <thead>
                                    <tr class="fs-8 text-muted">
                                        <th>Thuốc</th>
                                        <th>Liều lượng</th>
                                        <th>Tần suất</th>
                                        <th>Ngày</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="prescriptionBody">
                                    <!-- Dynamic rows added here -->
                                </tbody>
                            </table>
                        </div>

                        <button type="submit" class="btn btn-emerald btn-lg w-100 rounded-3 fw-bold py-3" style="background-color: #059669; color: white;">
                            <i class="bi bi-check-circle-fill"></i> Hoàn thành & Kê đơn thuốc
                        </button>
                    </form>
                }
                else
                {
                    <h3 class="fw-bold text-dark border-bottom pb-2 mb-4"><i class="bi bi-clipboard2-pulse"></i> Thông tin Lịch Hẹn</h3>
                    <div class="mb-4">
                        <p class="mb-1 text-muted">Bạn đang tư vấn với:</p>
                        <h4 class="fw-bold text-dark">@Model.Doctor.DoctorNavigation.FullName</h4>
                        <span class="badge bg-emerald-subtle text-emerald border px-3 py-1.5 rounded-pill fw-bold text-uppercase">@Model.Doctor.Specialty</span>
                    </div>

                    <div class="bg-light p-4 rounded-4 mb-4">
                        <h5 class="fw-bold"><i class="bi bi-info-circle"></i> Hướng dẫn</h5>
                        <p class="text-muted fs-7 mb-0" style="line-height: 1.6;">
                            Vui lòng ở lại phòng tư vấn. Bác sĩ đang thực hiện phiên khám và sẽ ghi chẩn đoán cùng đơn thuốc của bạn tại đây. Khi bác sĩ hoàn thành, bạn sẽ được tự động chuyển hướng để xem tóm tắt kết quả khám và chi tiết đơn thuốc.
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const userRole = "@role";

        if (userRole === "Doctor") {
            let selectedMedicines = [];

            $(document).ready(function() {
                // Search medicine
                $('#medicineSearch').on('input', function() {
                    let keyword = $(this).val();
                    if (keyword.length < 2) {
                        $('#searchResults').addClass('d-none');
                        return;
                    }

                    $.ajax({
                        url: '/Consultation/SearchMedicine',
                        type: 'GET',
                        data: { keyword: keyword },
                        success: function(data) {
                            let html = '';
                            if (data.length > 0) {
                                data.forEach(item => {
                                    html += `<button type="button" class="list-group-item list-group-item-action" onclick="addMedicine(${item.medicineId}, '${item.name}')">${item.name}</button>`;
                                });
                            } else {
                                html += `<div class="list-group-item text-muted">Không tìm thấy loại thuốc nào</div>`;
                            }
                            $('#searchResults').html(html).removeClass('d-none');
                        }
                    });
                });

                // Hide search results when clicking outside
                $(document).click(function(e) {
                    if (!$(e.target).closest('#medicineSearch, #searchResults').length) {
                        $('#searchResults').addClass('d-none');
                    }
                });

                // Handle Form submit
                $('#consultForm').submit(function() {
                    let items = [];
                    $('#prescriptionBody tr').each(function() {
                        let medId = $(this).data('med-id');
                        let dosage = $(this).find('.med-dosage').val();
                        let freq = $(this).find('.med-freq').val();
                        let days = $(this).find('.med-days').val();
                        items.push({
                            medicineId: parseInt(medId),
                            dosage: dosage,
                            frequency: freq,
                            durationDays: parseInt(days)
                        });
                    });
                    $('#prescriptionJson').val(JSON.stringify(items));
                    return true;
                });
            });

            function addMedicine(id, name) {
                // Prevent duplicate add
                if ($(`#med-row-${id}`).length > 0) {
                    $('#medicineSearch').val('');
                    $('#searchResults').addClass('d-none');
                    return;
                }

                let row = `
                    <tr id="med-row-${id}" data-med-id="${id}">
                        <td><span class="fw-semibold text-dark fs-7">${name}</span></td>
                        <td><input type="text" class="form-control form-control-sm med-dosage" value="500mg" placeholder="Liều lượng" required /></td>
                        <td><input type="text" class="form-control form-control-sm med-freq" value="2 lần / ngày" placeholder="Tần suất" required /></td>
                        <td><input type="number" class="form-control form-control-sm med-days" value="7" min="1" style="width: 60px;" required /></td>
                        <td><button type="button" class="btn btn-outline-danger btn-sm border-0" onclick="removeRow(${id})"><i class="bi bi-trash"></i></button></td>
                    </tr>
                `;
                $('#prescriptionBody').append(row);
                $('#medicineSearch').val('');
                $('#searchResults').addClass('d-none');
            }

            function removeRow(id) {
                $(`#med-row-${id}`).remove();
            }
        } else {
            // For patients, poll every 5 seconds to check if appointment status changed to Completed
            setInterval(function() {
                $.ajax({
                    url: '/Appointment/Index',
                    type: 'GET',
                    success: function() {
                        // Check if doctor completed consultation
                        // A more elegant solution is to check appointment status via JSON API:
                        $.getJSON('/EmergencyRequest/GetTrackingData', { requestId: 0 }, function() {
                            // Dummy, let's just query if appointment completed
                        }).fail(function() {
                            // Actually let's reload if redirected
                        });
                    }
                });
                
                // Let's check status directly by fetching Receipt view status or check DB
                // Redirect if appointment completes
                location.reload();
            }, 600000); // Poll slower or patient can refresh page when consultation ends.
        }
    </script>
}

<style>
    .animate-pulse {
        animation: pulse 1.5s infinite;
    }
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.4; }
        100% { opacity: 1; }
    }
    .text-emerald {
        color: #059669 !important;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
</style>
