@{
    ViewData["Title"] = "Yêu Cầu Xe Cứu Thương";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-danger shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-3">
                    <h3 class="card-title mb-0 fw-bold"><i class="bi bi-ambulance animate-pulse"></i> Điều Phối Xe Cứu Thương Khẩn Cấp</h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger rounded-3">@ViewBag.Error</div>
                    }

                    <div class="row g-4">
                        <!-- Left Form Column -->
                        <div class="col-md-5">
                            <form asp-action="SubmitRequest" method="post">
                                <input type="hidden" name="latitude" id="latitudeInput" value="" />
                                <input type="hidden" name="longitude" id="longitudeInput" value="" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold text-secondary">Địa điểm đón (Địa chỉ chính xác)</label>
                                    <textarea name="pickupLocation" id="addressInput" class="form-control rounded-3" rows="3" required placeholder="Nhập số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold text-secondary">Chi tiết tình trạng khẩn cấp (Không bắt buộc)</label>
                                    <textarea name="emergencyDetails" class="form-control rounded-3" rows="2" placeholder="Mô tả ngắn gọn về tình trạng nguy kịch..."></textarea>
                                </div>

                                <div class="alert alert-warning rounded-3 fs-7 py-2 px-3">
                                    <i class="bi bi-info-circle-fill me-1"></i> Mẹo: Sử dụng bản đồ bên phải để chọn vị trí chính xác của bạn giúp xe cứu thương định vị nhanh hơn.
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-danger btn-lg rounded-pill py-3 fw-bold"><i class="bi bi-exclamation-triangle"></i> YÊU CẦU XE CỨU THƯƠNG NGAY</button>
                                </div>
                            </form>
                        </div>

                        <!-- Right Map Column -->
                        <div class="col-md-7">
                            <label class="form-label fw-bold text-secondary">Định vị vị trí của bạn trên bản đồ</label>
                            <div class="border rounded-4 overflow-hidden shadow-sm" style="height: 350px; position: relative;">
                                <div id="selectMap" style="height: 100%; width: 100%; z-index: 1;"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-2 fs-8 text-muted">
                                <span>Vĩ độ đã chọn: <strong id="latText">N/A</strong></span>
                                <span>Kinh độ đã chọn: <strong id="lngText">N/A</strong></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        $(document).ready(function() {
            // Default center at HCMC center
            const defaultLat = 10.776;
            const defaultLng = 106.700;

            const map = L.map('selectMap').setView([defaultLat, defaultLng], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            let marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map)
                .bindPopup('<b>Kéo tôi</b> đến vị trí chính xác của bạn.').openPopup();

            // Set initial hidden inputs
            updateCoordinates(defaultLat, defaultLng);

            // Update coordinate fields on map click
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;
                marker.setLatLng([lat, lng]);
                updateCoordinates(lat, lng);
            });

            // Update coordinate fields on marker dragend
            marker.on('dragend', function(e) {
                const position = marker.getLatLng();
                updateCoordinates(position.lat, position.lng);
            });

            function updateCoordinates(lat, lng) {
                $('#latitudeInput').val(lat.toFixed(6));
                $('#longitudeInput').val(lng.toFixed(6));
                $('#latText').text(lat.toFixed(6));
                $('#lngText').text(lng.toFixed(6));
            }
        });
    </script>
}

<style>
    .fs-7 {
        font-size: 0.88rem;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
</style>
