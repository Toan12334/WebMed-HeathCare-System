@model WebMed_HeathCare_System.Models.Order

@{
    ViewData["Title"] = "Order Details - Pharmacist Admin";
}

<div class="container mt-5 mb-5">
    <!-- Back to Dashboard -->
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 mb-4"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Left Side: Order items list -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h4 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-receipt"></i> Items in Order #@Model.OrderId</h4>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr class="fs-8 text-muted">
                                <th>Medicine Name</th>
                                <th>Category</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Medicine.Name</div>
                                        @if (item.Medicine.IsPrescriptionRequired)
                                        {
                                            <span class="badge bg-danger-subtle text-danger fs-8 px-2 py-0.5 rounded-pill"><i class="bi bi-file-earmark-medical"></i> Rx Required</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-light text-dark">@item.Medicine.Category</span></td>
                                    <td class="text-center fw-bold">@item.Quantity</td>
                                    <td class="text-end">@item.PriceAtPurchase.ToString("N0") VND</td>
                                    <td class="text-end fw-bold">@((item.PriceAtPurchase * item.Quantity).ToString("N0")) VND</td>
                                </tr>
                            }
                            <tr class="border-top fw-extrabold text-dark fs-5">
                                <td colspan="4" class="text-end">Order Total:</td>
                                <td class="text-end text-success">@Model.TotalAmount.ToString("N0") VND</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Side: Status Control Panel -->
        <div class="col-lg-4">
            <!-- Delivery Info card -->
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Delivery Information</h5>
                <p class="mb-1 fs-7"><strong>Patient:</strong> @Model.Patient.PatientNavigation.FullName</p>
                <p class="mb-1 fs-7"><strong>Contact Phone:</strong> @Model.ShippingPhone</p>
                <p class="mb-1 fs-7"><strong>Address:</strong> @Model.ShippingAddress</p>
                <p class="mb-0 fs-7"><strong>Payment:</strong> @Model.PaymentMethod</p>
            </div>

            <!-- Workflow State Actions -->
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Order Status workflow</h5>
                
                <div class="mb-4">
                    <span class="text-muted d-block fs-8 text-uppercase fw-bold mb-1">Current State</span>
                    @if (Model.OrderStatus == "Pending")
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill fw-bold fs-7">Pending Payment</span>
                    }
                    else if (Model.OrderStatus == "Paid")
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold fs-7">Paid (Incoming Order)</span>
                    }
                    else if (Model.OrderStatus == "Preparing")
                    {
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold fs-7">Preparing Medicines</span>
                    }
                    else if (Model.OrderStatus == "Packed")
                    {
                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill fw-bold fs-7">Packed & Ready for Dispatch</span>
                    }
                    else if (Model.OrderStatus == "Shipping")
                    {
                        <span class="badge bg-info text-white px-3 py-2 rounded-pill fw-bold fs-7"><i class="bi bi-truck animate-bounce"></i> In Transit (Shipping)</span>
                    }
                    else if (Model.OrderStatus == "Completed")
                    {
                        <span class="badge bg-success text-white px-3 py-2 rounded-pill fw-bold fs-7">Delivered (Completed)</span>
                    }
                </div>

                <div class="d-grid gap-2">
                    @if (Model.OrderStatus == "Paid" || Model.OrderStatus == "Pending")
                    {
                        <form asp-action="StartPreparation" method="post">
                            <input type="hidden" name="id" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-play-fill"></i> Start Preparing Order</button>
                        </form>
                    }
                    else if (Model.OrderStatus == "Preparing")
                    {
                        <form asp-action="ConfirmPacked" method="post">
                            <input type="hidden" name="id" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-box-seam-fill"></i> Mark as Packed</button>
                        </form>
                    }
                    else if (Model.OrderStatus == "Packed")
                    {
                        <form asp-action="DispatchOrder" method="post">
                            <input type="hidden" name="id" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-info text-white btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-send-fill"></i> Hand Over to Courier (Ship)</button>
                        </form>
                    }
                    else if (Model.OrderStatus == "Shipping")
                    {
                        <form asp-action="CompleteOrder" method="post">
                            <input type="hidden" name="id" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-check-lg"></i> Mark as Delivered</button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100 rounded-3" disabled>Completed</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
    .fs-7 {
        font-size: 0.88rem;
    }
</style>
