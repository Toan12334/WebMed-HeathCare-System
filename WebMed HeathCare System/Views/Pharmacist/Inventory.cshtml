@model IEnumerable<WebMed_HeathCare_System.Models.Medicine>

@{
    ViewData["Title"] = "Quản Lý Kho Thuốc";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 border-bottom pb-3">
        <h1 class="fw-extrabold mb-0 text-dark"><i class="bi bi-box-seam-fill text-primary"></i> Quản Lý Kho Dược Phẩm & Thuốc</h1>
        <div>
            <button type="button" class="btn btn-success fw-bold rounded-pill px-4 me-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#addMedicineModal">
                <i class="bi bi-plus-lg"></i> Thêm thuốc mới
            </button>
            <a asp-action="Index" class="btn btn-outline-primary fw-bold rounded-pill px-4"><i class="bi bi-speedometer2"></i> Quay lại bảng điều khiển</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Inventory Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">Mã thuốc</th>
                                <th class="p-3">Tên thuốc</th>
                                <th class="p-3">Danh mục</th>
                                <th class="p-3 text-end">Giá</th>
                                <th class="p-3 text-center">Mức tồn kho</th>
                                <th class="p-3 text-center" style="width: 250px;">Nhập kho nhanh</th>
                                <th class="p-3 text-center" style="width: 120px;">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var med in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold text-muted">#@med.MedicineId</td>
                                    <td class="p-3">
                                        <div class="fw-bold text-dark fs-6">@med.Name</div>
                                        <small class="text-muted d-block text-truncate" style="max-width: 250px;">@med.Description</small>
                                    </td>
                                    <td class="p-3">
                                        <span class="badge bg-light text-secondary border px-3 py-1.5 rounded-pill">@med.Category</span>
                                    </td>
                                    <td class="p-3 text-end fw-extrabold text-dark">@med.Price.ToString("N0") VND</td>
                                    <td class="p-3 text-center">
                                        @if (med.StockQuantity == 0)
                                        {
                                            <span class="badge bg-danger text-white border px-3 py-1.5 rounded-pill fw-bold">Hết hàng (0)</span>
                                        }
                                        else if (med.StockQuantity < 15)
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-1.5 rounded-pill fw-bold">Sắp hết hàng (@med.StockQuantity)</span>
                                        }
                                        else if (med.StockQuantity < 50)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-1.5 rounded-pill fw-bold">Trung bình (@med.StockQuantity)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1.5 rounded-pill fw-bold">Đầy đủ (@med.StockQuantity)</span>
                                        }
                                    </td>
                                    <td class="p-3">
                                        <form asp-action="Restock" method="post" class="d-flex align-items-center gap-2 justify-content-center">
                                            <input type="hidden" name="medicineId" value="@med.MedicineId" />
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-plus-lg"></i></span>
                                                <input type="number" name="quantityToAdd" class="form-control border-start-0 ps-1" placeholder="SL" min="1" value="50" style="max-width: 80px;" required />
                                            </div>
                                            <button type="submit" class="btn btn-primary btn-sm rounded-3 fw-bold px-3 py-1.5 text-nowrap">
                                                <i class="bi bi-box-arrow-in-down"></i> Nhập kho
                                            </button>
                                        </form>
                                    </td>
                                    <td class="p-3 text-center">
                                        <button type="button" class="btn btn-outline-secondary btn-sm rounded-3 fw-bold px-3 edit-medicine-btn"
                                                data-id="@med.MedicineId"
                                                data-name="@med.Name"
                                                data-category="@med.Category"
                                                data-description="@med.Description"
                                                data-price="@((int)med.Price)"
                                                data-stock="@med.StockQuantity">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-clipboard2-x text-muted" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">Không có loại thuốc nào trong kho</h3>
                </div>
            }
        </div>
    </div>
</div>

<!-- ==========================================
     ADD MEDICINE MODAL
     ========================================== -->
<div class="modal fade" id="addMedicineModal" tabindex="-1" aria-labelledby="addMedicineModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="addMedicineModalLabel"><i class="bi bi-plus-circle-fill me-2 text-success"></i>Thêm Mới Dược Phẩm / Thuốc</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddMedicine" method="post">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên thuốc *</label>
                        <input type="text" name="name" class="form-control rounded-3" placeholder="Nhập tên thuốc..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục *</label>
                        <input type="text" name="category" class="form-control rounded-3" placeholder="Ví dụ: Giảm đau, Kháng sinh..." required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giá bán (VND) *</label>
                            <input type="number" name="price" class="form-control rounded-3" min="0" value="1000" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số lượng nhập kho *</label>
                            <input type="number" name="stockQuantity" class="form-control rounded-3" min="0" value="100" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Nhập mô tả, tác dụng phụ, hướng dẫn sử dụng..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Thêm thuốc</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ==========================================
     EDIT MEDICINE MODAL
     ========================================== -->
<div class="modal fade" id="editMedicineModal" tabindex="-1" aria-labelledby="editMedicineModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="editMedicineModalLabel"><i class="bi bi-pencil-square me-2 text-primary"></i>Chỉnh Sửa Thông Tin Thuốc</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="UpdateMedicine" method="post">
                <input type="hidden" name="medicineId" id="editMedicineId" />
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên thuốc *</label>
                        <input type="text" name="name" id="editName" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục *</label>
                        <input type="text" name="category" id="editCategory" class="form-control rounded-3" required />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Giá bán (VND) *</label>
                            <input type="number" name="price" id="editPrice" class="form-control rounded-3" min="0" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số lượng tồn kho *</label>
                            <input type="number" name="stockQuantity" id="editStock" class="form-control rounded-3" min="0" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea name="description" id="editDescription" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.edit-medicine-btn').on('click', function () {
                var id = $(this).data('id');
                var name = $(this).data('name');
                var category = $(this).data('category');
                var description = $(this).data('description');
                var price = $(this).data('price');
                var stock = $(this).data('stock');

                $('#editMedicineId').val(id);
                $('#editName').val(name);
                $('#editCategory').val(category);
                $('#editDescription').val(description);
                $('#editPrice').val(price);
                $('#editStock').val(stock);

                $('#editMedicineModal').modal('show');
            });
        });
    </script>
}
