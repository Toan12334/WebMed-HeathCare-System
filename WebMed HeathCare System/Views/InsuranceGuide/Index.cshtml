@model IEnumerable<WebMed_HeathCare_System.Models.InsurancePlan>

@{
    ViewData["Title"] = "Hướng Dẫn Bảo Hiểm";
}

<div class="container mt-4">
    <h2 class="mb-4">Các Gói Bảo Hiểm Sức Khỏe</h2>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var plan in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-primary">
                    <div class="card-header bg-primary text-white text-center">
                        <h4 class="my-0 font-weight-normal">@plan.PlanName</h4>
                    </div>
                    <div class="card-body text-center">
                        <h1 class="card-title pricing-card-title">@(plan.Pricing != null ? plan.Pricing.Premium.ToString("N0") : "N/A") <small class="text-muted">VND</small></h1>
                        <ul class="list-unstyled mt-3 mb-4">
                            <li>Thời hạn: @plan.DurationMonths tháng</li>
                            <li>Trạng thái: @(plan.IsActive == true ? "Hoạt động" : "Không hoạt động")</li>
                        </ul>
                        <a asp-action="Details" asp-route-id="@plan.PlanId" class="btn btn-lg btn-block btn-outline-primary w-100">Xem Chi Tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Count() >= 2)
    {
        <div class="card mt-4 bg-light">
            <div class="card-body">
                <h5 class="card-title">So Sánh Các Gói</h5>
                <form asp-action="Compare" method="get" class="row align-items-end">
                    <div class="col-md-4">
                        <label>Chọn Gói 1:</label>
                        <select name="plan1" class="form-select">
                            @foreach (var p in Model)
                            {
                                <option value="@p.PlanId">@p.PlanName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label>Chọn Gói 2:</label>
                        <select name="plan2" class="form-select">
                            @foreach (var p in Model)
                            {
                                <option value="@p.PlanId">@p.PlanName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-success w-100">So Sánh</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
