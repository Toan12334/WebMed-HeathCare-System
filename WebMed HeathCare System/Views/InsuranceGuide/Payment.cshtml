@model WebMed_HeathCare_System.Models.PatientInsurance

@{
    ViewData["Title"] = "Xử Lý Thanh Toán Bảo Hiểm";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary text-white p-4 text-center">
                    <i class="bi bi-shield-shaded" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">Cổng Bảo Hiểm WebMed</h3>
                    <p class="mb-0">Cổng Đăng Ký Bảo Hiểm Bảo Mật</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Mã bảo hiểm:</span>
                            <span class="fw-bold">#@Model.PatientInsuranceId</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tên gói:</span>
                            <span class="fw-bold text-dark">@Model.Plan.PlanName</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Phương thức thanh toán:</span>
                            <span class="fw-bold text-primary">@(((WebMed_HeathCare_System.Models.Payment)ViewBag.Payment).PaymentMethod)</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Số tiền cần thanh toán:</span>
                            <span class="fw-extrabold text-success fs-5">@(((WebMed_HeathCare_System.Models.Payment)ViewBag.Payment).Amount.ToString("N0")) VND</span>
                        </div>
                    </div>

                    <p class="text-center text-muted fs-7 mb-4">
                        Để giả lập giao dịch trực tuyến cho việc đăng ký bảo hiểm của bạn, vui lòng chọn một kết quả bên dưới.
                    </p>

                    <div class="d-grid gap-2">
                        <form asp-action="ProcessInsurancePayment" method="post">
                            <input type="hidden" name="patientInsuranceId" value="@Model.PatientInsuranceId" />
                            <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-check-circle-fill"></i> Giả lập Thanh toán Thành công</button>
                        </form>
                        
                        <form asp-action="FailInsurancePayment" method="post">
                            <input type="hidden" name="patientInsuranceId" value="@Model.PatientInsuranceId" />
                            <button type="submit" class="btn btn-danger btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-x-circle-fill"></i> Giả lập Thanh toán Thất bại</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-7 {
        font-size: 0.85rem;
    }
</style>
