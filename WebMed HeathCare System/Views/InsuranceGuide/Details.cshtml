@model WebMed_HeathCare_System.Models.InsurancePlanDetailsViewModel

@{
    ViewData["Title"] = Model.Plan.PlanName;
}

<div class="container mt-4">
    <a asp-action="Index" class="btn btn-secondary mb-3">&larr; Quay lại các gói</a>

    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h2 class="mb-0">@Model.Plan.PlanName</h2>
            <h3 class="mb-0 text-success">@(Model.Pricing != null ? Model.Pricing.Premium.ToString("N0") : "N/A") VND <small class="fs-6 text-light">/ @Model.Plan.DurationMonths tháng</small></h3>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Pricing & Network -->
                <div class="col-md-6 mb-4">
                    <h4 class="text-primary border-bottom pb-2">Thông tin giá gói</h4>
                    <table class="table table-borderless">
                        <tbody>
                            <tr><th>Khấu trừ:</th><td>@(Model.Pricing?.Deductible != null ? Model.Pricing.Deductible.Value.ToString("N0") + " VND" : "N/A")</td></tr>
                            <tr><th>Đồng thanh toán:</th><td>@(Model.Pricing?.Copay != null ? Model.Pricing.Copay.Value.ToString("N0") + " VND" : "N/A")</td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- Coverage Details -->
                <div class="col-md-6 mb-4">
                    <h4 class="text-primary border-bottom pb-2">Chi tiết quyền lợi bảo vệ</h4>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> @(Model.Coverage?.CoverageDetails ?? "Chưa có thông tin quyền lợi bảo vệ.")</li>
                    </ul>
                </div>
            </div>

            <div class="row mt-2">
                <!-- Benefits Information -->
                <div class="col-12">
                    <h4 class="text-primary border-bottom pb-2">Quyền lợi bổ sung</h4>
                    <div class="row">
                        @if (Model.Benefits != null && Model.Benefits.Any())
                        {
                            foreach (var benefit in Model.Benefits)
                            {
                                <div class="col-md-6 mb-2">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded p-2 me-3"><i class="bi bi-star-fill text-warning"></i></div>
                                        <div>@benefit.BenefitName</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12"><p>Không có quyền lợi bổ sung nào.</p></div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer text-center">
            <a asp-action="Enroll" asp-route-planId="@Model.Plan.PlanId" class="btn btn-lg btn-primary">Đăng Ký Ngay</a>
        </div>
    </div>
</div>
