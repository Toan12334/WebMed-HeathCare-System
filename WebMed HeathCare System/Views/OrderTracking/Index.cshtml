@model IEnumerable<WebMed_HeathCare_System.Models.Order>

@{
    ViewData["Title"] = "Đơn Hàng Của Tôi - WebMed";
}

<div class="container mt-5 mb-5">
    <h1 class="fw-extrabold mb-4"><i class="bi bi-box-seam"></i> Lịch Sử Đơn Hàng Dược Phẩm</h1>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                        <div class="card-header bg-light border-0 p-3 d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-dark">Đơn hàng #@order.OrderId</span>
                            <small class="text-muted">@order.CreatedAt.ToString("g")</small>
                        </div>
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-extrabold text-success mb-0">@order.TotalAmount.ToString("N0") <small class="fs-7 fw-normal text-muted">VND</small></h5>
                                    
                                    <!-- Status Badges -->
                                    @if (order.OrderStatus == "Paid")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1.5 rounded-pill fw-bold">Đã thanh toán</span>
                                    }
                                    else if (order.OrderStatus == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-1.5 rounded-pill fw-bold">Chờ thanh toán</span>
                                    }
                                    else if (order.OrderStatus == "Shipping")
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-1.5 rounded-pill fw-bold"><i class="bi bi-truck animate-bounce"></i> Đang giao hàng</span>
                                    }
                                    else if (order.OrderStatus == "Completed")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1.5 rounded-pill fw-bold">Đã giao hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-1.5 rounded-pill fw-bold">@order.OrderStatus</span>
                                    }
                                </div>

                                <h6 class="text-muted fw-bold fs-8 text-uppercase mb-2">Sản phẩm đã mua</h6>
                                <ul class="list-unstyled mb-4">
                                    @foreach (var item in order.OrderDetails.Take(3))
                                    {
                                        <li class="mb-1 text-dark fs-7"><i class="bi bi-capsule text-primary me-1"></i> @item.Medicine.Name (x@item.Quantity)</li>
                                    }
                                    @if (order.OrderDetails.Count() > 3)
                                    {
                                        <li class="text-muted fs-8">Và @(order.OrderDetails.Count() - 3) sản phẩm khác...</li>
                                    }
                                </ul>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-controller="Payment" asp-action="Index" asp-route-orderId="@order.OrderId" class="btn btn-outline-secondary rounded-3 w-50 fw-semibold">Hóa đơn</a>
                                <a asp-action="Track" asp-route-id="@order.OrderId" class="btn btn-primary rounded-3 w-50 fw-bold"><i class="bi bi-geo-alt-fill"></i> Theo dõi đơn</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 py-5 text-center">
            <div class="card-body">
                <i class="bi bi-clipboard2-x text-muted" style="font-size: 4rem;"></i>
                <h3 class="fw-bold mt-3">Không tìm thấy đơn hàng nào</h3>
                <p class="text-muted">Bạn hiện chưa đặt đơn hàng nào.</p>
                <a asp-controller="Pharmacy" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-2">Đến cửa hàng thuốc</a>
            </div>
        </div>
    }
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-7 {
        font-size: 0.88rem;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
</style>
