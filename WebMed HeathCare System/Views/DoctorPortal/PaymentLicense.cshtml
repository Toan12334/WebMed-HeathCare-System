@model WebMed_HeathCare_System.Models.DoctorLicense

@{
    ViewData["Title"] = "Thanh Toán Phí Thẩm Định Giấy Phép";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-warning text-dark p-4 text-center">
                    <i class="bi bi-wallet2" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">Phí Thẩm Định Giấy Phép</h3>
                    <p class="mb-0 text-dark-50">Nhà cung cấp xác thực bảo mật WebMed</p>
                </div>
                <div class="card-body p-4">
                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="d-flex justify-content-between mb-2 fs-7">
                            <span class="text-muted">Mã Giấy Phép:</span>
                            <span class="fw-bold">#@Model.LicenseId</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 fs-7">
                            <span class="text-muted">Số Giấy Phép:</span>
                            <span class="fw-bold text-primary">@Model.LicenseNumber</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Phí Thẩm Định:</span>
                            <strong class="text-success fs-4">@Model.FeeAmount.ToString("N0") VND</strong>
                        </div>
                    </div>

                    <p class="text-center text-muted fs-8 mb-4">
                        Bằng việc hoàn tất thanh toán này, bạn cho phép ban quản trị WebMed xem xét các chứng chỉ chuyên môn của bạn và kích hoạt hồ sơ chuyên gia của bạn.
                    </p>

                    <form asp-action="PayLicense" method="post">
                        <input type="hidden" name="licenseId" value="@Model.LicenseId" />
                        <button type="submit" class="btn btn-warning btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-shield-check"></i> Thanh Toán Phí & Xác Thực Tài Khoản</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.88rem;
    }
    .fs-8 {
        font-size: 0.8rem;
    }
</style>
