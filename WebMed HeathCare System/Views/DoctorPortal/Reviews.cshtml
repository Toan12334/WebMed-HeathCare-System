@model IEnumerable<WebMed_HeathCare_System.Models.DoctorReview>

@{
    ViewData["Title"] = "Bảng Điều Khiển Đánh Giá Của Bệnh Nhân - Cổng Bác Sĩ";
    var doctor = (WebMed_HeathCare_System.Models.Doctor)ViewBag.Doctor;
}

<div class="container mt-5 mb-5">
    <h1 class="fw-extrabold mb-4"><i class="bi bi-star-fill text-warning"></i> Phản Hồi & Đánh Giá Của Bệnh Nhân</h1>

    <div class="row g-4 mb-5">
        <!-- Summary Stats Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                <h6 class="text-muted text-uppercase fw-bold fs-8 mb-2">Đánh Giá Sao Trung Bình</h6>
                <h1 class="display-3 fw-extrabold text-dark mb-2">@doctor.AverageRating.ToString("F1")</h1>
                
                <div class="d-flex justify-content-center text-warning fs-3 mb-3">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(doctor.AverageRating))
                        {
                            <i class="bi bi-star-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-star"></i>
                        }
                    }
                </div>
                
                <span class="badge bg-light text-muted border px-3 py-1.5 rounded-pill fw-semibold">Dựa trên @Model.Count() đánh giá</span>
            </div>
        </div>

        <!-- Rating details distribution mockup -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3">Chi Tiết Đánh Giá</h5>
                
                <!-- 5 stars -->
                <div class="d-flex align-items-center mb-2 fs-7">
                    <span style="width: 50px;">5 <i class="bi bi-star-fill text-warning"></i></span>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width: @(Model.Any() ? (Model.Count(r => r.Rating == 5) * 100 / Model.Count()) : 0)%"></div>
                    </div>
                    <span class="text-muted">@Model.Count(r => r.Rating == 5)</span>
                </div>
                
                <!-- 4 stars -->
                <div class="d-flex align-items-center mb-2 fs-7">
                    <span style="width: 50px;">4 <i class="bi bi-star-fill text-warning"></i></span>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width: @(Model.Any() ? (Model.Count(r => r.Rating == 4) * 100 / Model.Count()) : 0)%"></div>
                    </div>
                    <span class="text-muted">@Model.Count(r => r.Rating == 4)</span>
                </div>

                <!-- 3 stars -->
                <div class="d-flex align-items-center mb-2 fs-7">
                    <span style="width: 50px;">3 <i class="bi bi-star-fill text-warning"></i></span>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-warning" style="width: @(Model.Any() ? (Model.Count(r => r.Rating == 3) * 100 / Model.Count()) : 0)%"></div>
                    </div>
                    <span class="text-muted">@Model.Count(r => r.Rating == 3)</span>
                </div>

                <!-- 2 stars -->
                <div class="d-flex align-items-center mb-2 fs-7">
                    <span style="width: 50px;">2 <i class="bi bi-star-fill text-warning"></i></span>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-danger" style="width: @(Model.Any() ? (Model.Count(r => r.Rating == 2) * 100 / Model.Count()) : 0)%"></div>
                    </div>
                    <span class="text-muted">@Model.Count(r => r.Rating == 2)</span>
                </div>

                <!-- 1 star -->
                <div class="d-flex align-items-center fs-7">
                    <span style="width: 50px;">1 <i class="bi bi-star-fill text-warning"></i></span>
                    <div class="progress flex-grow-1 mx-3" style="height: 8px;">
                        <div class="progress-bar bg-danger" style="width: @(Model.Any() ? (Model.Count(r => r.Rating == 1) * 100 / Model.Count()) : 0)%"></div>
                    </div>
                    <span class="text-muted">@Model.Count(r => r.Rating == 1)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Feedback List -->
    <div class="card border-0 shadow-sm rounded-4 p-4">
        <h4 class="fw-bold text-dark border-bottom pb-2 mb-4">Đánh giá từ bệnh nhân</h4>
        
        @if (Model != null && Model.Any())
        {
            <div class="row g-3">
                @foreach (var rev in Model)
                {
                    <div class="col-12">
                        <div class="bg-light p-3 rounded-3 hover-shadow transition-all">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-subtle text-primary rounded-circle p-2 me-2 fs-8"><i class="bi bi-person-fill"></i></div>
                                    <strong class="text-dark">@rev.Patient.PatientNavigation.FullName</strong>
                                </div>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= rev.Rating)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                </div>
                            </div>
                            <p class="text-muted fs-7 mb-1" style="line-height: 1.5;">@rev.Comment</p>
                            <small class="text-muted fs-8 d-block text-end">@rev.CreatedAt.ToString("g")</small>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-left-dots text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-2">Chưa có đánh giá nào từ bệnh nhân.</p>
            </div>
        }
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-8 {
        font-size: 0.78rem;
    }
    .fs-7 {
        font-size: 0.88rem;
    }
</style>
