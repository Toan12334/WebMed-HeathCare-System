@model WebMed_HeathCare_System.Models.Order

@{
    ViewData["Title"] = "Process Online Payment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-primary text-white p-4 text-center">
                    <i class="bi bi-bank" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">WebMed Payment Gateway</h3>
                    <p class="mb-0">Secure Transaction Gateway</p>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Order ID:</span>
                            <span class="fw-bold">#@Model.OrderId</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Payment Method:</span>
                            <span class="fw-bold text-primary">@Model.PaymentMethod</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Amount to Pay:</span>
                            <span class="fw-extrabold text-success fs-5">@Model.TotalAmount.ToString("N0") VND</span>
                        </div>
                    </div>

                    <p class="text-center text-muted fs-7 mb-4">
                        To simulate an online transaction, please select an outcome below. In a production environment, you would be redirected to the banking/gateway portal.
                    </p>

                    <div class="d-grid gap-2">
                        <form asp-action="ProcessPayment" method="post">
                            <input type="hidden" name="orderId" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-check-circle-fill"></i> Simulate Payment Success</button>
                        </form>
                        
                        <form asp-action="FailPayment" method="post">
                            <input type="hidden" name="orderId" value="@Model.OrderId" />
                            <button type="submit" class="btn btn-danger btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-x-circle-fill"></i> Simulate Payment Failure</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-7 {
        font-size: 0.85rem;
    }
</style>
