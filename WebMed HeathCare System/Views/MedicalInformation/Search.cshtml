@model IEnumerable<WebMed_HeathCare_System.Models.Article>

@{
    ViewData["Title"] = "Thông Tin Y Tế - WebMed Portal";

    // Mapping Database category names to Vietnamese display titles
    var categoryMapping = new Dictionary<string, string>
    {
        { "News", "Tin Tức" },
        { "Notifications", "Thông Báo" },
        { "Hospital Activities", "Hoạt Động Bệnh Viện" },
        { "Research", "Nghiên Cứu Khoa Học" },
        { "Events", "Hội Thảo Và Sự Kiện" },
        { "Cooperation", "Hợp Tác" },
        { "Training", "Đào Tạo" },
        { "Community", "Hoạt Động Cộng Đồng" },
        { "Pharma Info", "Thông Tin Dược" },
        { "Recruitment", "Tuyển Dụng" },
        { "Success Stories", "Câu Chuyện Thành Công" }
    };

    var selectedCatKey = ViewBag.SelectedCategory as string ?? "";
    var displayCategoryName = !string.IsNullOrEmpty(selectedCatKey) && categoryMapping.ContainsKey(selectedCatKey)
        ? categoryMapping[selectedCatKey]
        : "Tin Tức & Sự Kiện Mới Nhất";

    // Helper to get realistic Unsplash images based on Category or ID
    string GetArticleImage(int id, string category, string imageUrl)
    {
        if (!string.IsNullOrEmpty(imageUrl))
        {
            return imageUrl;
        }
        var images = new[]
        {
            "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&w=800&q=80", // Hospital
            "https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&w=800&q=80", // Conference
            "https://images.unsplash.com/photo-1576086213369-97a306d36557?auto=format&fit=crop&w=800&q=80", // Research
            "https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?auto=format&fit=crop&w=800&q=80", // Pediatric
            "https://images.unsplash.com/photo-1581594693702-fbdc51b2763b?auto=format&fit=crop&w=800&q=80", // Success baby
            "https://images.unsplash.com/photo-1505751172876-fa1923c5c528?auto=format&fit=crop&w=800&q=80", // Medical team
            "https://images.unsplash.com/photo-1584515979956-d9f6e5d09982?auto=format&fit=crop&w=800&q=80", // Doctor consulting
            "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=800&q=80"  // Stethoscope
        };
        
        if (category == "Events") return images[1];
        if (category == "Research") return images[2];
        if (category == "Success Stories") return images[4];
        if (category == "News") return images[0];
        
        return images[id % images.Length];
    }
}

<div class="container mt-4 pb-5">
    <!-- Search Bar -->
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8">
            <form asp-action="Search" method="get">
                <input type="hidden" name="category" value="@ViewBag.SelectedCategory" />
                <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border">
                    <span class="input-group-text bg-white border-0 ps-4"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="keyword" class="form-control border-0 py-3" 
                           placeholder="Nhập từ khóa tìm kiếm tin tức y khoa..." value="@ViewBag.Keyword" />
                    <button type="submit" class="btn btn-primary px-5 fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Main Content Area: Sidebar + Grid -->
    <div class="row">
        <!-- Sidebar Categories -->
        <div class="col-lg-3 mb-4">
            <div class="bg-white rounded-4 shadow-sm border border-light overflow-hidden">
                <div class="p-3 bg-light border-bottom">
                    <h5 class="fw-bold text-dark mb-0 fs-6"><i class="bi bi-journal-medical me-2"></i>Danh mục tin</h5>
                </div>
                <div class="list-group list-group-flush category-sidebar-list">
                    <!-- All Categories -->
                    <a href="?category=&keyword=@ViewBag.Keyword" 
                       class="list-group-item list-group-item-action py-3 px-4 fw-semibold fs-7 @(string.IsNullOrEmpty(selectedCatKey) ? "active-category" : "")">
                        Tất cả tin tức
                    </a>
                    
                    @foreach (var cat in (List<string>)ViewBag.Categories)
                    {
                        var vietnameseName = categoryMapping.ContainsKey(cat) ? categoryMapping[cat] : cat;
                        <a href="?category=@cat&keyword=@ViewBag.Keyword" 
                           class="list-group-item list-group-item-action py-3 px-4 fw-semibold fs-7 @(selectedCatKey == cat ? "active-category" : "")">
                            @vietnameseName
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Right Content: News Feed -->
        <div class="col-lg-9">
            <!-- Selected Category Title -->
            <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
                <h3 class="fw-bold text-dark mb-0 text-uppercase tracking-wide" style="font-size: 1.5rem;">
                    @displayCategoryName
                </h3>
                @if (Model != null && Model.Any())
                {
                    <span class="badge bg-emerald-100 text-emerald-800 px-3 py-1 rounded-pill fw-semibold">
                        @Model.Count() bài viết
                    </span>
                }
            </div>

            @if (Model != null && Model.Any())
            {
                var articlesList = Model.ToList();
                var featured = articlesList.First();
                var nextThree = articlesList.Skip(1).Take(2).ToList();
                var others = articlesList.Skip(3).ToList();

                <div class="row g-4 mb-5">
                    <!-- Main Featured Article (Left Side) -->
                    <div class="col-lg-8">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift transition-all">
                            <a asp-action="Details" asp-route-id="@featured.ArticleId" class="text-decoration-none">
                                <div class="position-relative" style="height: 280px; overflow: hidden;">
                                    <img src="@GetArticleImage(featured.ArticleId, featured.Category, featured.ImageUrl)" 
                                         alt="@featured.Title" class="w-100 h-100 object-cover" />
                                    <span class="position-absolute top-0 start-0 bg-primary text-white px-3 py-1 m-3 rounded-pill fs-8 fw-semibold text-uppercase">
                                        @(categoryMapping.ContainsKey(featured.Category) ? categoryMapping[featured.Category] : featured.Category)
                                    </span>
                                </div>
                                <div class="card-body p-4">
                                    <span class="text-muted d-block mb-2 fs-8"><i class="bi bi-calendar-event me-1"></i>@featured.PublishedAt.ToString("dd/MM/yyyy")</span>
                                    <h4 class="fw-bold text-dark mb-2 hover-primary" style="line-height: 1.3;">
                                        @featured.Title
                                    </h4>
                                    <p class="text-muted fs-7 mb-0 line-clamp-3">
                                        @featured.Content
                                    </p>
                                </div>
                            </a>
                        </div>
                    </div>

                    <!-- Next 2 Articles (Right Side list) -->
                    <div class="col-lg-4 d-flex flex-column gap-4">
                        @if (nextThree.Any())
                        {
                            @foreach (var article in nextThree)
                            {
                                <div class="card border-0 shadow-sm rounded-4 overflow-hidden flex-grow-1 hover-lift transition-all">
                                    <a asp-action="Details" asp-route-id="@article.ArticleId" class="text-decoration-none d-flex flex-column h-100">
                                        <div style="height: 140px; overflow: hidden; position: relative;">
                                            <img src="@GetArticleImage(article.ArticleId, article.Category, article.ImageUrl)" 
                                                 alt="@article.Title" class="w-100 h-100 object-cover" />
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                                            <h6 class="fw-bold text-dark mb-2 line-clamp-2" style="font-size: 0.95rem; line-height: 1.3;">
                                                @article.Title
                                            </h6>
                                            <span class="text-muted fs-8 d-block"><i class="bi bi-calendar-event me-1"></i>@article.PublishedAt.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                        else
                        {
                            <!-- Fallback placeholders if only 1 article exists -->
                            <div class="bg-light rounded-4 d-flex align-items-center justify-content-center p-4 text-center text-muted" style="height: 100%;">
                                <div>
                                    <i class="bi bi-journal-text fs-3 mb-2 d-block"></i>
                                    Cập nhật các thông tin y tế chuyên sâu tại WebMed.
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Remaining Articles List (Older articles) -->
                @if (others.Any())
                {
                    <h5 class="fw-bold text-dark mb-4"><i class="bi bi-clock-history me-2"></i>Các tin tức khác</h5>
                    <div class="row g-4">
                        @foreach (var article in others)
                        {
                            <div class="col-md-6">
                                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-lift transition-all">
                                    <a asp-action="Details" asp-route-id="@article.ArticleId" class="text-decoration-none d-flex flex-row h-100">
                                        <div style="width: 130px; min-width: 130px; overflow: hidden; position: relative;">
                                            <img src="@GetArticleImage(article.ArticleId, article.Category, article.ImageUrl)" 
                                                 alt="@article.Title" class="w-100 h-100 object-cover" />
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column justify-content-between">
                                            <div>
                                                <h6 class="fw-bold text-dark mb-1 line-clamp-2" style="font-size: 0.9rem; line-height: 1.3;">
                                                    @article.Title
                                                </h6>
                                                <p class="text-muted fs-8 mb-0 line-clamp-2">@article.Content</p>
                                            </div>
                                            <span class="text-muted fs-8 d-block mt-2"><i class="bi bi-calendar-event me-1"></i>@article.PublishedAt.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-white rounded-4 shadow-sm border border-light">
                    <i class="bi bi-newspaper text-muted mb-3" style="font-size: 4rem;"></i>
                    <h4 class="fw-bold">Chưa có bài viết nào</h4>
                    <p class="text-muted px-4">Không tìm thấy bài viết nào thuộc danh mục này. Vui lòng quay lại sau hoặc thử từ khóa khác.</p>
                    <a href="?" class="btn btn-primary rounded-pill px-4 mt-2">Xem tất cả bài viết</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.9rem !important;
    }
    .fs-8 {
        font-size: 0.8rem !important;
    }
    .object-cover {
        object-fit: cover;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.06) !important;
    }
    .transition-all {
        transition: all 0.25s ease-in-out;
    }
    
    /* Line Clamping for consistent layout */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    
    .hover-primary:hover {
        color: var(--primary-color) !important;
    }

    /* Sidebar list styling */
    .category-sidebar-list .list-group-item {
        border-left: 4px solid transparent;
        color: #475569;
        transition: all 0.2s ease;
    }
    .category-sidebar-list .list-group-item:hover {
        background-color: #f8fafc;
        color: var(--primary-color);
        padding-left: 1.75rem !important;
    }
    .category-sidebar-list .active-category {
        background-color: #f0fdf4 !important;
        border-left: 4px solid var(--primary-color) !important;
        color: var(--primary-color) !important;
    }
</style>
