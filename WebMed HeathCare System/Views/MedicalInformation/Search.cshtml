@model IEnumerable<WebMed_HeathCare_System.Models.Article>

@{
    ViewData["Title"] = "Medical Information Search";
}

<h2>Medical Information Search</h2>

<form asp-action="Search" method="post" class="mb-4">
    <div class="input-group">
        <input type="text" name="keyword" class="form-control" placeholder="Enter keyword to search..." value="@ViewBag.Keyword" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning">
        @ViewBag.Message
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="list-group">
        @foreach (var article in Model)
        {
            <a asp-action="Details" asp-route-id="@article.ArticleId" class="list-group-item list-group-item-action">
                <h5 class="mb-1">@article.Title</h5>
                <small class="text-muted">Category: @article.Category | Published: @article.PublishedAt.ToString("MMM dd, yyyy")</small>
            </a>
        }
    </div>
}
