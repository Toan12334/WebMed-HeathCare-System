@model IEnumerable<WebMed_HeathCare_System.Models.Role>

@{
    ViewData["Title"] = "System Roles & Permissions - Admin Console";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <h1 class="fw-extrabold mb-4 text-dark"><i class="bi bi-shield-lock-fill"></i> System Roles & Permissions</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header Actions & Navigation Tabs -->
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-6">
            <button type="button" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#createRoleModal">
                <i class="bi bi-plus-circle-fill me-1"></i> Add New Role
            </button>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group shadow-sm">
                <a asp-action="Users" class="btn btn-outline-primary">Users</a>
                <a asp-action="Doctors" class="btn btn-outline-primary">Doctor Verification</a>
                <a asp-action="Reviews" class="btn btn-outline-primary">Review Moderation</a>
                <a asp-action="News" class="btn btn-outline-primary">Health News</a>
                <a asp-action="Roles" class="btn btn-primary active">System Roles</a>
            </div>
        </div>
    </div>

    <!-- Roles Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3" style="width: 100px;">Role ID</th>
                                <th class="p-3" style="width: 250px;">Role Name</th>
                                <th class="p-3">Description</th>
                                <th class="p-3 text-center" style="width: 200px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold">#@role.RoleId</td>
                                    <td class="p-3 fw-bold text-dark">
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1.5 rounded-pill fs-7">
                                            @role.RoleName
                                        </span>
                                    </td>
                                    <td class="p-3 text-muted">@role.Description</td>
                                    <td class="p-3 text-center">
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <button type="button" class="btn btn-outline-secondary btn-sm rounded-3 fw-bold px-3 edit-role-btn" 
                                                    data-id="@role.RoleId" 
                                                    data-name="@role.RoleName" 
                                                    data-desc="@role.Description">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </button>

                                            <form asp-action="DeleteRole" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete role @role.RoleName?');">
                                                <input type="hidden" name="id" value="@role.RoleId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 fw-bold px-3" title="Delete Role">
                                                    <i class="bi bi-trash3-fill"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-shield-slash text-muted" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">No system roles found</h3>
                    <p class="text-muted">Create a role to get started.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ==========================================
     CREATE ROLE MODAL
     ========================================== -->
<div class="modal fade" id="createRoleModal" tabindex="-1" aria-labelledby="createRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="createRoleModalLabel"><i class="bi bi-plus-circle-fill me-2 text-primary"></i>Create New System Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateRole" method="post">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Role Name</label>
                        <input type="text" name="roleName" class="form-control rounded-3" placeholder="e.g. Pharmacist, SupportStaff" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control rounded-3" rows="3" placeholder="Describe permissions and access rights..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Create Role</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ==========================================
     EDIT ROLE MODAL
     ========================================== -->
<div class="modal fade" id="editRoleModal" tabindex="-1" aria-labelledby="editRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="editRoleModalLabel"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit System Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditRole" method="post">
                <input type="hidden" name="roleId" id="editRoleId" />
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Role Name</label>
                        <input type="text" name="roleName" id="editRoleName" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" id="editRoleDesc" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
    .fs-7 {
        font-size: 0.85rem;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.edit-role-btn').on('click', function () {
                var roleId = $(this).data('id');
                var roleName = $(this).data('name');
                var roleDesc = $(this).data('desc');

                $('#editRoleId').val(roleId);
                $('#editRoleName').val(roleName);
                $('#editRoleDesc').val(roleDesc);

                $('#editRoleModal').modal('show');
            });
        });
    </script>
}
