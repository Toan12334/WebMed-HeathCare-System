@model IEnumerable<WebMed_HeathCare_System.Models.Role>

@{
    ViewData["Title"] = "System Roles & Permissions - Admin Console";
    var systemRoles = new HashSet<string> { "Admin", "Doctor", "Pharmacist", "Patient" };
}

<div class="container mt-4 pb-5">
    <!-- Success / Error Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Header Block -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 border-bottom pb-3">
        <h1 class="fw-bold mb-0 text-dark"><i class="bi bi-shield-lock-fill text-primary"></i> System Roles</h1>
        <div class="btn-group shadow-sm">
            <a asp-action="Users" class="btn btn-outline-primary">Users</a>
            <a asp-action="Doctors" class="btn btn-outline-primary">Doctor Verification</a>
            <a asp-action="Reviews" class="btn btn-outline-primary">Review Moderation</a>
            <a asp-action="News" class="btn btn-outline-primary">Health News</a>
            <a asp-action="Roles" class="btn btn-primary active">System Roles</a>
        </div>
    </div>

    <!-- Action Bar -->
    <div class="mb-4">
        <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#createRoleModal">
            <i class="bi bi-plus-lg me-1"></i> Add New Role
        </button>
    </div>

    <!-- Roles Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">Role ID</th>
                                <th class="p-3">Role Name</th>
                                <th class="p-3">Description</th>
                                <th class="p-3 text-center">Type</th>
                                <th class="p-3 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model)
                            {
                                var isSystem = systemRoles.Contains(role.RoleName);
                                <tr>
                                    <td class="p-3 fw-bold text-secondary">#@role.RoleId</td>
                                    <td class="p-3">
                                        <span class="badge bg-light text-primary border border-primary px-3 py-1.5 rounded-pill fw-semibold">
                                            @role.RoleName
                                        </span>
                                    </td>
                                    <td class="p-3 text-muted">@role.Description</td>
                                    <td class="p-3 text-center">
                                        @if (isSystem)
                                        {
                                            <span class="badge bg-primary-subtle text-primary border px-2.5 py-1 rounded">System Core</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border px-2.5 py-1 rounded">Custom</span>
                                        }
                                    </td>
                                    <td class="p-3 text-end">
                                        <button type="button" class="btn btn-outline-dark btn-sm rounded-3 px-3 me-1 fw-semibold" 
                                                data-bs-toggle="modal" data-bs-target="#editRoleModal-@role.RoleId">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </button>
                                        @if (!isSystem)
                                        {
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-3 px-3 fw-semibold" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteRoleModal-@role.RoleId">
                                                <i class="bi bi-trash-fill me-1"></i> Delete
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-outline-secondary btn-sm rounded-3 px-3 fw-semibold" disabled title="System Core Roles cannot be deleted">
                                                <i class="bi bi-trash-fill me-1"></i> Locked
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-5 text-center text-muted">
                    <i class="bi bi-shield-slash fs-1 d-block mb-3"></i>
                    <h3 class="fw-bold">No system roles found</h3>
                </div>
            }
        </div>
    </div>
</div>

<!-- Render Modals Outside Table to avoid DOM layout glitches -->
@if (Model != null && Model.Any())
{
    @foreach (var role in Model)
    {
        var isSystem = systemRoles.Contains(role.RoleName);

        <!-- Edit Modal -->
        <div class="modal fade" id="editRoleModal-@role.RoleId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4">
                    <div class="modal-header border-0 bg-light p-3">
                        <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square text-primary me-2"></i>Edit Role</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="EditRole" method="post">
                        <input type="hidden" name="roleId" value="@role.RoleId" />
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Role Name</label>
                                @if (isSystem)
                                {
                                    <input type="text" name="roleName" class="form-control rounded-3" value="@role.RoleName" readonly style="background-color: #f8fafc;" />
                                    <div class="form-text text-danger"><i class="bi bi-info-circle"></i> System core roles cannot be renamed to prevent application routing issues.</div>
                                }
                                else
                                {
                                    <input type="text" name="roleName" class="form-control rounded-3" value="@role.RoleName" required />
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Description</label>
                                <textarea name="description" class="form-control rounded-3" rows="3" required>@role.Description</textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-3 bg-light">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Delete Modal -->
        @if (!isSystem)
        {
            <div class="modal fade" id="deleteRoleModal-@role.RoleId" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg rounded-4">
                        <div class="modal-header border-0 bg-light p-3">
                            <h5 class="modal-title fw-bold text-danger"><i class="bi bi-trash-fill me-2"></i>Delete Role</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form asp-action="DeleteRole" method="post">
                            <input type="hidden" name="id" value="@role.RoleId" />
                            <div class="modal-body p-4 text-center">
                                <i class="bi bi-exclamation-octagon-fill text-danger fs-1 mb-3 d-block"></i>
                                <p class="mb-0 text-dark fw-semibold">Are you sure you want to delete the role <span class="badge bg-danger px-3 py-1.5 rounded-pill text-white">@role.RoleName</span>?</p>
                                <p class="small text-muted mt-2">This action cannot be undone and is only allowed if no users are currently assigned to this role.</p>
                            </div>
                            <div class="modal-footer border-0 p-3 bg-light justify-content-center">
                                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">Delete Permanent</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
}

<!-- Create Role Modal -->
<div class="modal fade" id="createRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 bg-light p-3">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-shield-plus text-success me-2"></i>Add New System Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateRole" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Role Name</label>
                        <input type="text" name="roleName" class="form-control rounded-3" required placeholder="e.g. Nurse" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Description</label>
                        <textarea name="description" class="form-control rounded-3" rows="3" required placeholder="Brief summary of role permissions..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Create Role</button>
                </div>
            </form>
        </div>
    </div>
</div>
