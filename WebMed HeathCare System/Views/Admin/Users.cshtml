@model IEnumerable<WebMed_HeathCare_System.Models.User>

@{
    ViewData["Title"] = "User Account Management - Admin Console";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <h1 class="fw-extrabold mb-4 text-dark"><i class="bi bi-people-fill"></i> User Accounts Management</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form & Navigation Links -->
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-6">
            <form asp-action="Users" method="get" class="d-flex bg-white shadow-sm rounded-pill p-1 overflow-hidden">
                <input type="text" name="searchEmail" class="form-control border-0 px-4 py-2 rounded-pill" placeholder="Search by name or email..." value="@ViewBag.SearchEmail" style="box-shadow: none;" />
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Search</button>
            </form>
        </div>
        <div class="col-md-6 text-md-end">
            <div class="btn-group shadow-sm">
                <a asp-action="Users" class="btn btn-primary active">Users</a>
                <a asp-action="Doctors" class="btn btn-outline-primary">Doctor Verification</a>
                <a asp-action="Reviews" class="btn btn-outline-primary">Review Moderation</a>
                <a asp-action="News" class="btn btn-outline-primary">Health News</a>
            </div>
        </div>
    </div>

    <!-- Accounts Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">User ID</th>
                                <th class="p-3">Full Name</th>
                                <th class="p-3">Email Address</th>
                                <th class="p-3">Phone</th>
                                <th class="p-3 text-center">Role</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3 text-center" style="width: 180px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold">#@user.UserId</td>
                                    <td class="p-3 fw-bold text-dark">@user.FullName</td>
                                    <td class="p-3 text-muted">@user.Email</td>
                                    <td class="p-3 text-muted">@user.PhoneNumber</td>
                                    <td class="p-3 text-center">
                                        <span class="badge bg-light text-dark border">@user.Role?.RoleName</span>
                                    </td>
                                    <td class="p-3 text-center">
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1.5 rounded-pill fw-bold">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-1.5 rounded-pill fw-bold">Suspended</span>
                                        }
                                    </td>
                                    <td class="p-3 text-center">
                                        <form asp-action="SuspendUser" method="post">
                                            <input type="hidden" name="id" value="@user.UserId" />
                                            @if (user.IsActive)
                                            {
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 w-100 fw-bold"><i class="bi bi-person-x-fill"></i> Suspend</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-outline-success btn-sm rounded-3 w-100 fw-bold"><i class="bi bi-person-check-fill"></i> Activate</button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">No user accounts found</h3>
                    <p class="text-muted">Modify your search query.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
</style>
