@model IEnumerable<WebMed_HeathCare_System.Models.User>

@{
    ViewData["Title"] = "User Account Management - Admin Console";
    var roles = ViewBag.Roles as IEnumerable<WebMed_HeathCare_System.Models.Role> ?? new List<WebMed_HeathCare_System.Models.Role>();
}

<div class="container-fluid mt-4 px-4 mb-5">
    <h1 class="fw-extrabold mb-4 text-dark"><i class="bi bi-people-fill"></i> User Accounts Management</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form, Action Buttons & Navigation Links -->
    <div class="row g-3 mb-4 align-items-center">
        <div class="col-md-5">
            <form asp-action="Users" method="get" class="d-flex bg-white shadow-sm rounded-pill p-1 overflow-hidden">
                <input type="text" name="searchEmail" class="form-control border-0 px-4 py-2 rounded-pill" placeholder="Search by name or email..." value="@ViewBag.SearchEmail" style="box-shadow: none;" />
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Search</button>
            </form>
        </div>
        <div class="col-md-7 text-md-end d-flex justify-content-md-end align-items-center gap-2 flex-wrap">
            <button type="button" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="bi bi-person-plus-fill me-1"></i> Add New User
            </button>
            <div class="btn-group shadow-sm">
                <a asp-action="Users" class="btn btn-primary active">Users</a>
                <a asp-action="Doctors" class="btn btn-outline-primary">Doctor Verification</a>
                <a asp-action="Reviews" class="btn btn-outline-primary">Review Moderation</a>
                <a asp-action="News" class="btn btn-outline-primary">Health News</a>
                <a asp-action="Roles" class="btn btn-outline-primary">System Roles</a>
            </div>
        </div>
    </div>

    <!-- Accounts Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">User ID</th>
                                <th class="p-3">Full Name</th>
                                <th class="p-3">Email Address</th>
                                <th class="p-3">Phone</th>
                                <th class="p-3 text-center">Role</th>
                                <th class="p-3 text-center">Status</th>
                                <th class="p-3 text-center" style="width: 220px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold">#@user.UserId</td>
                                    <td class="p-3 fw-bold text-dark">@user.FullName</td>
                                    <td class="p-3 text-muted">@user.Email</td>
                                    <td class="p-3 text-muted">@user.PhoneNumber</td>
                                    <td class="p-3 text-center">
                                        <span class="badge bg-light text-dark border">@user.Role?.RoleName</span>
                                    </td>
                                    <td class="p-3 text-center">
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1.5 rounded-pill fw-bold">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-1.5 rounded-pill fw-bold">Suspended</span>
                                        }
                                    </td>
                                    <td class="p-3 text-center">
                                        <div class="d-flex justify-content-center align-items-center gap-1">
                                            <button type="button" class="btn btn-outline-secondary btn-sm rounded-3 fw-bold px-3 edit-user-btn" data-id="@user.UserId">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </button>
                                            
                                            <form asp-action="SuspendUser" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@user.UserId" />
                                                @if (user.IsActive)
                                                {
                                                    <button type="submit" class="btn btn-outline-warning btn-sm rounded-3 fw-bold" title="Suspend Account"><i class="bi bi-person-x-fill"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-outline-success btn-sm rounded-3 fw-bold" title="Activate Account"><i class="bi bi-person-check-fill"></i></button>
                                                }
                                            </form>

                                            <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete user @user.FullName? This will soft-delete their account.');">
                                                <input type="hidden" name="id" value="@user.UserId" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 fw-bold" title="Delete User"><i class="bi bi-trash3-fill"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">No user accounts found</h3>
                    <p class="text-muted">Modify your search query.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- ==========================================
     CREATE USER MODAL
     ========================================== -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="createUserModalLabel"><i class="bi bi-person-plus-fill me-2 text-primary"></i>Create New User Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateUser" method="post" id="createUserForm">
                <div class="modal-body px-4 py-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Username</label>
                            <input type="text" name="username" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Password</label>
                            <input type="password" name="password" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" name="fullName" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" name="email" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phone Number</label>
                            <input type="text" name="phoneNumber" class="form-control rounded-3" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Role</label>
                            <select name="roleId" class="form-select rounded-3 role-select" required>
                                <option value="">-- Select Role --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role.RoleId">@role.RoleName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Doctor Specific Fields -->
                    <div class="doctor-fields mt-3 p-3 bg-light rounded-3 d-none border">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-briefcase-fill me-2"></i>Doctor Professional Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Specialty</label>
                                <input type="text" name="specialty" class="form-control rounded-3" placeholder="e.g., Cardiology, Pediatrics" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Clinic Location</label>
                                <input type="text" name="location" class="form-control rounded-3" placeholder="e.g., Room 102, Building A" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Biography (Bio)</label>
                                <textarea name="bio" class="form-control rounded-3" rows="3" placeholder="Brief summary of doctor experience..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Patient Specific Fields -->
                    <div class="patient-fields mt-3 p-3 bg-light rounded-3 d-none border">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-heart-pulse-fill me-2"></i>Patient Profile Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Date of Birth</label>
                                <input type="date" name="dob" class="form-control rounded-3" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Gender</label>
                                <select name="gender" class="form-select rounded-3">
                                    <option value="">-- Select Gender --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Blood Type</label>
                                <select name="bloodType" class="form-select rounded-3">
                                    <option value="">-- Select Blood Type --</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Address</label>
                                <input type="text" name="address" class="form-control rounded-3" placeholder="Residential Address" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ==========================================
     EDIT USER MODAL
     ========================================== -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 bg-light rounded-top-4 py-3 px-4">
                <h5 class="modal-title fw-bold" id="editUserModalLabel"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit User Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="EditUser" method="post" id="editUserForm">
                <input type="hidden" name="userId" id="editUserId" />
                <div class="modal-body px-4 py-3">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Username (Read-Only)</label>
                            <input type="text" id="editUsername" class="form-control rounded-3 bg-light" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">New Password (Leave blank to keep current)</label>
                            <input type="password" name="password" class="form-control rounded-3" placeholder="••••••••" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" name="fullName" id="editFullName" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" name="email" id="editEmail" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phone Number</label>
                            <input type="text" name="phoneNumber" id="editPhoneNumber" class="form-control rounded-3" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Role</label>
                            <select name="roleId" id="editRoleId" class="form-select rounded-3 role-select" required>
                                <option value="">-- Select Role --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role.RoleId">@role.RoleName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Doctor Specific Fields -->
                    <div class="doctor-fields mt-3 p-3 bg-light rounded-3 d-none border">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-briefcase-fill me-2"></i>Doctor Professional Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Specialty</label>
                                <input type="text" name="specialty" id="editSpecialty" class="form-control rounded-3" placeholder="e.g., Cardiology, Pediatrics" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Clinic Location</label>
                                <input type="text" name="location" id="editLocation" class="form-control rounded-3" placeholder="e.g., Room 102, Building A" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">Biography (Bio)</label>
                                <textarea name="bio" id="editBio" class="form-control rounded-3" rows="3" placeholder="Brief summary of doctor experience..."></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Patient Specific Fields -->
                    <div class="patient-fields mt-3 p-3 bg-light rounded-3 d-none border">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-heart-pulse-fill me-2"></i>Patient Profile Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Date of Birth</label>
                                <input type="date" name="dob" id="editDob" class="form-control rounded-3" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Gender</label>
                                <select name="gender" id="editGender" class="form-select rounded-3">
                                    <option value="">-- Select Gender --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Blood Type</label>
                                <select name="bloodType" id="editBloodType" class="form-select rounded-3">
                                    <option value="">-- Select Blood Type --</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Address</label>
                                <input type="text" name="address" id="editAddress" class="form-control rounded-3" placeholder="Residential Address" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light rounded-bottom-4 py-3 px-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Function to handle role change and toggle field visibility
            function handleRoleFields(selectElement) {
                var selectedText = selectElement.find("option:selected").text().toLowerCase().trim();
                var modal = selectElement.closest('.modal-content');
                var doctorSection = modal.find('.doctor-fields');
                var patientSection = modal.find('.patient-fields');

                if (selectedText === 'doctor') {
                    doctorSection.removeClass('d-none');
                    patientSection.addClass('d-none');
                } else if (selectedText === 'patient') {
                    patientSection.removeClass('d-none');
                    doctorSection.addClass('d-none');
                } else {
                    doctorSection.addClass('d-none');
                    patientSection.addClass('d-none');
                }
            }

            // Bind role dropdown change event
            $('.role-select').on('change', function () {
                handleRoleFields($(this));
            });

            // Bind edit button click event
            $('.edit-user-btn').on('click', function () {
                var userId = $(this).data('id');
                
                // Fetch User Details via AJAX
                $.ajax({
                    url: '/Admin/GetUserDetails/' + userId,
                    type: 'GET',
                    success: function (data) {
                        // Populate basic details
                        $('#editUserId').val(data.userId);
                        $('#editUsername').val(data.username);
                        $('#editFullName').val(data.fullName);
                        $('#editEmail').val(data.email);
                        $('#editPhoneNumber').val(data.phoneNumber);
                        $('#editRoleId').val(data.roleId);

                        // Trigger role fields view toggle
                        handleRoleFields($('#editRoleId'));

                        // Clear and populate Doctor details if any
                        if (data.doctor) {
                            $('#editSpecialty').val(data.doctor.specialty);
                            $('#editLocation').val(data.doctor.location);
                            $('#editBio').val(data.doctor.bio);
                        } else {
                            $('#editSpecialty').val('');
                            $('#editLocation').val('');
                            $('#editBio').val('');
                        }

                        // Clear and populate Patient details if any
                        if (data.patient) {
                            $('#editDob').val(data.patient.dob);
                            $('#editGender').val(data.patient.gender);
                            $('#editAddress').val(data.patient.address);
                            $('#editBloodType').val(data.patient.bloodType);
                        } else {
                            $('#editDob').val('');
                            $('#editGender').val('');
                            $('#editAddress').val('');
                            $('#editBloodType').val('');
                        }

                        // Show the edit modal
                        $('#editUserModal').modal('show');
                    },
                    error: function () {
                        alert('Error occurred while fetching user details. Please try again.');
                    }
                });
            });
        });
    </script>
}
