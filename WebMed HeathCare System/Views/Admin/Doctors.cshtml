@model IEnumerable<WebMed_HeathCare_System.Models.DoctorLicense>

@{
    ViewData["Title"] = "Doctor Verification Requests - Admin Console";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <h1 class="fw-extrabold mb-4 text-dark"><i class="bi bi-patch-check-fill text-primary"></i> Doctor Profile Verification</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Navigation Buttons -->
    <div class="d-flex justify-content-end mb-4">
        <div class="btn-group shadow-sm">
            <a asp-action="Users" class="btn btn-outline-primary">Users</a>
            <a asp-action="Doctors" class="btn btn-primary active">Doctor Verification</a>
            <a asp-action="Reviews" class="btn btn-outline-primary">Review Moderation</a>
            <a asp-action="News" class="btn btn-outline-primary">Health News</a>
        </div>
    </div>

    <!-- Verification Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">License ID</th>
                                <th class="p-3">Doctor Name</th>
                                <th class="p-3">Specialty</th>
                                <th class="p-3">License Number</th>
                                <th class="p-3">Uploaded Document</th>
                                <th class="p-3 text-center">Submitted At</th>
                                <th class="p-3 text-center" style="width: 250px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold">#@request.LicenseId</td>
                                    <td class="p-3 fw-bold text-dark">@request.Doctor.DoctorNavigation.FullName</td>
                                    <td class="p-3 text-muted">@request.Doctor.Specialty</td>
                                    <td class="p-3"><code class="text-dark">@request.LicenseNumber</code></td>
                                    <td class="p-3">
                                        <a href="@request.DocumentUrl" target="_blank" class="text-decoration-none"><i class="bi bi-file-pdf text-danger"></i> View Certificate</a>
                                    </td>
                                    <td class="p-3 text-center text-muted">@request.SubmittedAt.ToString("d")</td>
                                    <td class="p-3 text-center">
                                        <div class="d-flex gap-2">
                                            <form asp-action="VerifyDoctor" method="post" class="w-50">
                                                <input type="hidden" name="licenseId" value="@request.LicenseId" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button type="submit" class="btn btn-success btn-sm w-100 rounded-3 fw-bold"><i class="bi bi-check-lg"></i> Approve</button>
                                            </form>
                                            <form asp-action="VerifyDoctor" method="post" class="w-50">
                                                <input type="hidden" name="licenseId" value="@request.LicenseId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit" class="btn btn-danger btn-sm w-100 rounded-3 fw-bold"><i class="bi bi-x-lg"></i> Reject</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-shield-fill-check text-success" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">All profiles verified</h3>
                    <p class="text-muted">No pending doctor verification requests at the moment.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
</style>
