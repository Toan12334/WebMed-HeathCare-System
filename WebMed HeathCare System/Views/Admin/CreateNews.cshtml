@{
    ViewData["Title"] = "Write News Article - Admin Panel";
}

<div class="container mt-5 mb-5">
    <a asp-action="News" class="btn btn-outline-secondary rounded-pill px-4 mb-4"><i class="bi bi-arrow-left"></i> Back to News Management</a>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h3 class="fw-bold text-dark border-bottom pb-2 mb-4"><i class="bi bi-file-earmark-medical-fill"></i> Write Health News Article</h3>

                <form asp-action="CreateNews" method="post">
                    <!-- Title -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Article Title</label>
                        <input type="text" name="title" class="form-control rounded-3 form-control-lg" required placeholder="e.g. 5 Benefits of Daily Morning Workouts" />
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Category</label>
                        <select name="category" class="form-select rounded-3">
                            <option value="Wellness">Wellness & Health</option>
                            <option value="Nutrition">Nutrition & Diet</option>
                            <option value="Medical">Medical Science</option>
                            <option value="Mental">Mental Health</option>
                        </select>
                    </div>

                    <!-- Content -->
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Article Content</label>
                        <textarea name="content" class="form-control rounded-3" rows="8" required placeholder="Write the main article body content here..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3 fw-bold py-3"><i class="bi bi-send-fill"></i> Publish News Article</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
</style>
