@model IEnumerable<WebMed_HeathCare_System.Models.Article>

@{
    ViewData["Title"] = "Bài Viết Tin Tức Sức Khỏe - Bảng Điều Khiển Admin";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <!-- Header Block -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 border-bottom pb-3">
        <h1 class="fw-extrabold mb-0 text-dark"><i class="bi bi-newspaper text-primary"></i> Tin Tức Sức Khỏe</h1>
        <div class="btn-group shadow-sm">
            <a asp-action="Users" class="btn btn-outline-primary">Người dùng</a>
            <a asp-action="Doctors" class="btn btn-outline-primary">Xác thực bác sĩ</a>
            <a asp-action="Reviews" class="btn btn-outline-primary">Kiểm duyệt đánh giá</a>
            <a asp-action="News" class="btn btn-primary active">Tin tức sức khỏe</a>
            <a asp-action="Roles" class="btn btn-outline-primary">Vai trò hệ thống</a>
            <a asp-action="Emergencies" class="btn btn-outline-primary">Điều phối cấp cứu</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Action Bar -->
    <div class="mb-4">
        <a asp-action="CreateNews" class="btn btn-primary rounded-pill px-4 fw-bold"><i class="bi bi-plus-lg"></i> Tạo Bài Viết Tin Tức</a>
    </div>

    <!-- Health News List -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="p-3">Mã tin</th>
                                <th class="p-3">Tiêu đề Bài viết</th>
                                <th class="p-3">Chuyên mục</th>
                                <th class="p-3">Tác giả</th>
                                <th class="p-3 text-center">Ngày đăng</th>
                                <th class="p-3 text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var article in Model)
                            {
                                <tr>
                                    <td class="p-3 fw-bold">#@article.ArticleId</td>
                                    <td class="p-3 fw-bold text-dark">@article.Title</td>
                                    <td class="p-3"><span class="badge bg-light text-primary border">@article.Category</span></td>
                                    <td class="p-3">@article.Author.FullName</td>
                                    <td class="p-3 text-center text-muted">@article.PublishedAt.ToString("g")</td>
                                    <td class="p-3 text-center">
                                        @if (article.IsPublished)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1.5 rounded-pill fw-bold">Đã xuất bản</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-1.5 rounded-pill fw-bold">Bản nháp</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="py-5 text-center">
                    <i class="bi bi-file-earmark-medical text-muted" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-3">Không tìm thấy bài viết nào</h3>
                    <p class="text-muted">Bạn chưa viết hoặc xuất bản bất kỳ bài viết sức khỏe nào.</p>
                    <a asp-action="CreateNews" class="btn btn-primary rounded-pill px-4 mt-2">Viết bài viết</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }
</style>
